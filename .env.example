# Copiez ce fichier en .env (ou lancez ./setup.sh) puis renseignez vos valeurs.
# Les scripts (generate_dataset.py, svg_fit.py --from-llm-svg) chargent .env
# automatiquement au démarrage. Ne committez jamais votre .env.

# Fournisseur LLM par défaut : anthropic | deepseek
LLM_PROVIDER=anthropic

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# URL de base (optionnelle ; défaut : https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- DeepSeek (API compatible OpenAI) ---
DEEPSEEK_API_KEY=
# URL de base (défaut : https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com
